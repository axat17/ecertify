{
  "name": "releaseiq-api",
  "version": "1.0.0",
  "description": "ReleaseIQ Backend API - ADP Release Management Platform",
  "main": "dist/server.js",
  "scripts": {
    "dev": "ts-node-dev --respawn --transpile-only src/server.ts",
    "build": "tsc",
    "start": "node dist/server.js",
    "start:dit": "NODE_ENV=dit node dist/server.js",
    "start:fit": "NODE_ENV=fit node dist/server.js",
    "start:iat": "NODE_ENV=iat node dist/server.js",
    "start:prod": "NODE_ENV=production node dist/server.js",
    "lint": "eslint src --ext .ts",
    "seed": "ts-node src/utils/seed.ts",
    "test": "jest --runInBand"
  },
  "dependencies": {
    "express": "^4.18.2",
    "mongoose": "^7.6.3",
    "cors": "^2.8.5",
    "helmet": "^7.0.0",
    "dotenv": "^16.3.1",
    "jsonwebtoken": "^9.0.2",
    "bcryptjs": "^2.4.3",
    "express-rate-limit": "^7.1.1",
    "express-validator": "^7.0.1",
    "winston": "^3.11.0",
    "morgan": "^1.10.0",
    "node-cron": "^3.0.3",
    "axios": "^1.6.0",
    "uuid": "^9.0.0",
    "joi": "^17.11.0",
    "compression": "^1.7.4",
    "express-async-errors": "^3.1.1"
  },
  "devDependencies": {
    "@types/express": "^4.17.20",
    "@types/cors": "^2.8.16",
    "@types/morgan": "^1.9.8",
    "@types/bcryptjs": "^2.4.5",
    "@types/jsonwebtoken": "^9.0.4",
    "@types/node": "^20.8.10",
    "@types/uuid": "^9.0.6",
    "@types/compression": "^1.7.4",
    "@types/node-cron": "^3.0.10",
    "@types/jest": "^29.5.7",
    "ts-node": "^10.9.1",
    "ts-node-dev": "^2.0.0",
    "typescript": "^5.2.2",
    "jest": "^29.7.0",
    "ts-jest": "^29.1.1",
    "eslint": "^8.52.0",
    "@typescript-eslint/eslint-plugin": "^6.9.1",
    "@typescript-eslint/parser": "^6.9.1"
  }
}
